# API Keys da universidade (iaedu.pt)
# Copia este ficheiro para .env.local e preenche os valores

AGENT_OPUS47_KEY=sk-usr-...
AGENT_GPT55_KEY=sk-usr-...
AGENT_GPT4O_KEY=sk-usr-...

# Supabase / Prisma (obter em supabase.com > Project Settings > Database)
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgres://postgres.[project-ref]:[password]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres?sslmode=require"
